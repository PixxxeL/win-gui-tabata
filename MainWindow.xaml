<Window x:Class="ScheduleTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Таймер Расписания" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верх: Название расписания -->
        <TextBlock x:Name="LblTitle" Grid.Row="0" 
                   Text="Загрузка..." FontSize="28" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,20,0,10"/>

        <!-- Центр: Кольцо прогресса и таймер -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Фоновое кольцо -->
            <Ellipse Width="340" Height="340" Stroke="#333333" StrokeThickness="16" Fill="None"/>

            <!-- Активное кольцо прогресса -->
            <Ellipse x:Name="RingProgress" Width="340" Height="340" 
                     Stroke="#00BFFF" StrokeThickness="16" Fill="None"
                     StrokeDashArray="1068.14" StrokeStartPoint="0.5,0">
                <Ellipse.RenderTransform>
                    <ScaleTransform ScaleX="-1" ScaleY="1" CenterX="170" CenterY="170"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Цифры -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtHours" FontSize="32" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#AAAAAA"/>
                <TextBlock x:Name="TxtMinutes" FontSize="80" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=":" FontSize="40" VerticalAlignment="Center" Foreground="#AAAAAA"/>
                <TextBlock x:Name="TxtSeconds" FontSize="32" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="#AAAAAA"/>
            </StackPanel>

            <!-- Подпись фазы -->
            <TextBlock x:Name="LblPhase" Grid.Row="1" VerticalAlignment="Bottom" 
                       HorizontalAlignment="Center" FontSize="16" Foreground="#888888" Margin="0,0,0,40"/>
        </Grid>

        <!-- Низ: Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
            <Button x:Name="BtnPlay" Width="70" Height="70" Margin="15" Click="BtnPlay_Click" Background="#2E7D32" BorderBrush="{x:Null}">
                <Path Data="M0,0 L24,12 L0,24 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="BtnPause" Width="70" Height="70" Margin="15" Click="BtnPause_Click" Background="#F57C00" BorderBrush="{x:Null}">
                <Path Data="M0,0 L8,0 L8,24 L0,24 Z M16,0 L24,0 L24,24 L16,24 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="BtnStop" Width="70" Height="70" Margin="15" Click="BtnStop_Click" Background="#C62828" BorderBrush="{x:Null}">
                <Path Data="M0,0 L24,0 L24,24 L0,24 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>