<Window x:Class="ScheduleTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xml:lang="en-US"
        Title="Таймер Расписания" Height="640" Width="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanMinimize" FontFamily="Segoe UI" Foreground="White"
        PreviewKeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Кнопка управления: серый градиент, скруглённый квадрат, синяя полоска -->
        <Style x:Key="CtrlButton" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="14" BorderThickness="1" BorderBrush="#3A3F4A">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2E333D" Offset="0"/>
                                    <GradientStop Color="#21252D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Неоновый бордер с отступом: виден всегда, ярче/светится по состоянию -->
                                <Border x:Name="glowBorder" Margin="2" CornerRadius="11"
                                        BorderThickness="1.6" BorderBrush="#3B82F6" Opacity="0.4"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="glowBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <!-- Активное состояние (Tag=active): яркий неоновый бордер со свечением -->
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="glowBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="glowBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="glowBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="16" ShadowDepth="0" Opacity="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Мини-кнопка заголовка (звук / свернуть / закрыть) -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="#8A909C"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Корневая «карточка»: перетаскивание за любое место (кнопки перехватывают свои клики сами) -->
    <Border CornerRadius="16" BorderThickness="1" BorderBrush="#2A2E37"
            MouseLeftButtonDown="TitleBar_MouseDown">
        <Border.Background>
            <!-- Лёгкий диагональный градиент: чуть светлее в верхнем-левом углу,
                 мягкая средняя ступень, темнее в нижнем-правом — даёт объём, не меняя тёмный тон -->
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E222C" Offset="0"/>
                <GradientStop Color="#171A21" Offset="0.55"/>
                <GradientStop Color="#0F1116" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
        <Grid x:Name="RootGrid" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Строка заголовка: звук/свернуть/закрыть (перетаскивание — на корневом Border) -->
            <Grid Grid.Row="0" Height="40" Background="Transparent">
                <TextBlock x:Name="LblCaption" Text="⏱  Таймер расписания" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontSize="12" Foreground="#6C7280"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="BtnSound" Style="{StaticResource CaptionButton}" Content="&#xE767;"
                            Click="BtnSound_Click"/>
                    <Button x:Name="BtnMinimize" Style="{StaticResource CaptionButton}" Content="&#xE921;"
                            Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnClose" Style="{StaticResource CaptionButton}" Content="&#xE8BB;"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Циферблат на всю площадь + наложенный текст (название / время / период) -->
            <!-- Клик по кругу «подматывает» время; за пределами круга окно тянется как обычно -->
            <Grid x:Name="DialArea" Grid.Row="1" Margin="22,6,22,4" Background="Transparent"
                  SizeChanged="DialArea_SizeChanged" MouseLeftButtonDown="Dial_MouseDown"
                  MouseMove="DialArea_MouseMove" MouseLeave="DialArea_MouseLeave">
                <!-- Мягкое голубое пятно-подсветка, следует за курсором по кольцу рисок.
                     Нижний слой (над фоном, под рисками/текстом); позиция — в code-behind
                     через HoverGlowT. Центрируется в области, смещается TranslateTransform. -->
                <Ellipse x:Name="HoverGlow" Width="112" Height="112"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Opacity="0" IsHitTestVisible="False"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="HoverGlowT"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#4455AEEF" Offset="0"/>
                            <GradientStop Color="#1A55AEEF" Offset="0.55"/>
                            <GradientStop Color="#0055AEEF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="24"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Риски генерируются в code-behind (BuildTicks); размер задаётся по факту -->
                <Canvas x:Name="TicksCanvas" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="LblTitle" Text="Загрузка..." TextAlignment="Center"
                               FontSize="20" FontWeight="SemiBold" Foreground="#E8EAED"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>

                    <!-- Двоеточия — отдельные блоки с фиксированным мелким размером
                         (код их не масштабирует, только цифры) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtHours" FontSize="30" FontWeight="Light"
                                   VerticalAlignment="Center" Foreground="#8A909C"/>
                        <TextBlock x:Name="ColonH" Text=":" FontSize="30" FontWeight="Light"
                                   VerticalAlignment="Center" Foreground="#8A909C" Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtMinutes" Text="00" FontSize="82" FontWeight="Light"
                                   VerticalAlignment="Center" Foreground="#FFFFFF"/>
                        <TextBlock Text=":" FontSize="30" FontWeight="Light"
                                   VerticalAlignment="Center" Foreground="#8A909C"/>
                        <TextBlock x:Name="TxtSeconds" Text="00" FontSize="30" FontWeight="Light"
                                   VerticalAlignment="Center" Foreground="#8A909C"/>
                    </StackPanel>

                    <TextBlock x:Name="LblPhase" Text="" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,2,0,0"
                               FontSize="14" Foreground="#8A909C"/>
                </StackPanel>
            </Grid>

            <!-- Кнопки управления + мелкая версия внизу -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnPlay" Style="{StaticResource CtrlButton}"
                            Margin="0,0,10,0" Click="BtnPlay_Click" ToolTip="Старт / Продолжить (Пробел)">
                        <Path Data="M 0 0 L 15 8 L 0 16 Z" Fill="White" Margin="3,0,0,0"/>
                    </Button>
                    <Button x:Name="BtnPause" Style="{StaticResource CtrlButton}"
                            Margin="10,0" Click="BtnPause_Click" ToolTip="Пауза / Продолжить (Пробел)">
                        <Path Data="M 0 0 L 5 0 L 5 16 L 0 16 Z M 10 0 L 15 0 L 15 16 L 10 16 Z" Fill="White"/>
                    </Button>
                    <Button x:Name="BtnStop" Style="{StaticResource CtrlButton}"
                            Margin="10,0,0,0" Click="BtnStop_Click" ToolTip="Стоп (S)">
                        <Path Data="M 0 0 L 15 0 L 15 15 L 0 15 Z" Fill="White"/>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="LblVersion" Text="v1.0.0" HorizontalAlignment="Center"
                           Margin="0,8,0,0" FontSize="9" Foreground="#4A4F59"/>
            </StackPanel>
        </Grid>

        <!-- Затемнение поверх содержимого, пока открыто модальное окно (итоги).
             Само содержимое дополнительно блурится в code-behind (ShowSummary). -->
        <Border x:Name="ModalDim" CornerRadius="15" Background="#99060910"
                Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>
